# Test-specific overrides — loaded before .env.database in setup-env.ts (first-wins),
# so these values take precedence over .env.database when running E2E tests.
LYA_DB_URL=mongodb://lya:lya@mongodb:27017/lya_test
LYA_JWT_SECRET=test-jwt-secret
LYA_JWT_REFRESH_SECRET=test-jwt-refresh-secret
LYA_JWT_EXPIRY=15m
LYA_JWT_REFRESH_EXPIRY=7d
